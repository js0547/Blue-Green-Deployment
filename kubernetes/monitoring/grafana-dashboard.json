{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Unauthorized Access Attempts (HTTP 403s)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=\"403\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_cpu_usage * 100",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Active Traffic (Blue vs Green Environment cutover visualization)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{color=\"blue\"}[1m]))",
          "legendFormat": "Blue Environment",
          "refId": "Blue"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{color=\"green\"}[1m]))",
          "legendFormat": "Green Environment",
          "refId": "Green"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
